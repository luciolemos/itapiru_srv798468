<header class="db-navbar" aria-label="Barra superior do dashboard">
  <div class="db-navbar-row">
    <div class="db-navbar-actions">
      <div class="db-navbar-left">
        <button
          type="button"
          class="db-sidebar-toggle"
          data-sidebar-toggle
          aria-controls="db-sidebar"
          aria-expanded="false"
          aria-label="Alternar menu lateral"
        >
          <i class="bi bi-list" aria-hidden="true"></i>
        </button>
      </div>


        <div class="db-navbar-right">
          {% if isAdminLogged %}
          {% set pendingCount = adminPendingRequestsCount|default(0) %}
          {% set pendingItems = adminPendingRequests|default([]) %}

          <details class="db-notification-menu" data-notification-menu>
            <summary class="db-notification-toggle" aria-label="Abrir notificações de solicitações">
              <i class="bi bi-bell" aria-hidden="true"></i>
              <span class="db-notification-badge{{ pendingCount == 0 ? ' is-zero' : '' }}" aria-label="{{ pendingCount }} solicitações pendentes">
                {{ pendingCount > 99 ? '99+' : pendingCount }}
              </span>
            </summary>

            <div class="db-notification-panel" role="menu" aria-label="Solicitações pendentes">
              <div class="db-notification-header">
                <strong>Solicitações pendentes</strong>
                <span>{{ pendingCount }}</span>
              </div>

              {% if pendingItems is not empty %}
                <div class="db-notification-list">
                  {% for pendingItem in pendingItems %}
                    <a
                      class="db-notification-item"
                      data-request-id="{{ pendingItem.id|default(0) }}"
                      role="menuitem"
                      href="{{ app_base_path }}/admin?entity=requests&request_status=pending&request_q={{ pendingItem.title|default('')|url_encode }}"
                      hx-boost="false"
                    >
                      <span class="db-notification-item-title">{{ pendingItem.title|default('Sem título') }}</span>
                      <span class="db-notification-item-meta">
                        #{{ pendingItem.id|default('-') }} · {{ pendingItem.requester_rank|default('') }} {{ pendingItem.requester_name|default('') }}
                      </span>
                    </a>
                  {% endfor %}
                </div>
              {% else %}
                <p class="db-notification-empty">Nenhuma solicitação pendente no momento.</p>
              {% endif %}

              <a class="db-notification-footer" href="{{ app_base_path }}/admin?entity=requests&request_status=pending" hx-boost="false">Abrir lista de solicitações</a>
            </div>
          </details>

        {% set userDisplayName = adminUsername|default('')|trim %}
        {% if userDisplayName == '' %}
          {% set userDisplayName = 'admin' %}
        {% endif %}

        <details class="db-user-menu" data-user-menu>
          <summary class="db-user-menu-toggle" aria-label="Abrir menu do usuário">
            <span class="db-user-avatar" data-initial="{{ userDisplayName|slice(0, 1)|upper }}" aria-hidden="true">
              <img
                src="{{ adminAvatarUrl|default(asset_base_path ~ '/assets/img/avatar/face6_620_620.png') }}"
                alt=""
                loading="lazy"
                onerror="this.parentElement.classList.add('is-fallback'); this.remove();"
              >
            </span>
            <span class="db-user-name">{{ userDisplayName }}</span>
            <i class="bi bi-chevron-down" aria-hidden="true"></i>
          </summary>

          <div class="db-user-menu-panel" role="menu" aria-label="Menu do usuário">
            <a class="db-user-menu-item" role="menuitem" href="{{ app_base_path }}/admin/account">Conta</a>
            <form method="post" action="{{ app_base_path }}/logout" hx-boost="false" class="db-user-menu-form">
              <input type="hidden" name="csrf_token" value="{{ csrfToken|default('') }}">
              <button class="db-user-menu-item is-danger" type="submit">Sair</button>
            </form>
          </div>
        </details>
        {% endif %}
      </div>
    </div>
  </div>
</header>

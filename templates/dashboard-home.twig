{% extends 'layouts/base.twig' %}

{% block title %}16º BI Mtz{% endblock %}

{% block content %}
<div class="db-shell">
  <aside id="db-sidebar" class="db-sidebar" data-sidebar aria-label="Menu de seções">
    <div class="db-sidebar-header">
      <img
        class="db-om-logo"
        src="{{ asset_base_path }}/assets/img/om.png"
        alt="Imagem institucional"
      >
      <h1 class="db-brand">{{ dashboardTitle }}</h1>
      <p class="db-caption">{{ dashboardSubtitle }}</p>
    </div>

    <nav class="db-menu" aria-label="Navegação de seções">
      <a href="{{ app_url() }}" hx-boost="false" class="db-menu-item{{ activeSection == 'home' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'home' ? 'page' : 'false' }}">
        <i class="bi bi-speedometer2" aria-hidden="true"></i>
        <span>PAINEL DE CONTROLE</span>
      </a>
      <span class="db-menu-divider" aria-hidden="true"></span>
      {% set sidebarGroups = groupedSections|default([]) %}
      {% for group in sidebarGroups %}
        {% set groupSlugs = group.items|keys %}
        {% set isGroupOpen = activeSection is defined and activeSection in groupSlugs %}
        <section class="db-menu-group-block" data-menu-group>
          <button
            type="button"
            class="db-menu-group-toggle"
            data-menu-group-toggle
            data-group-key="group-{{ loop.index0 }}-{{ group.label|lower|trim|replace({' ': '-'}) }}"
            aria-expanded="{{ isGroupOpen ? 'true' : 'false' }}"
          >
            <span class="db-menu-group">{{ group.label }}</span>
            <i class="bi bi-chevron-down" aria-hidden="true"></i>
          </button>
          <div class="db-menu-group-items" data-menu-group-items {{ isGroupOpen ? '' : 'hidden' }}>
            {% for slug, section in group.items %}
              <a
                href="{{ app_base_path }}/{{ slug }}"
                hx-boost="false"
                class="db-menu-item{{ activeSection == slug ? ' is-active' : '' }}"
                aria-current="{{ activeSection == slug ? 'page' : 'false' }}"
              >
                {{ section.label }}
              </a>
              {% if not loop.last %}
                <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
              {% endif %}
            {% endfor %}
          </div>
        </section>
        {% if not loop.last %}
          <span class="db-menu-divider" aria-hidden="true"></span>
        {% endif %}
      {% endfor %}
      <span class="db-menu-divider" aria-hidden="true"></span>
      {% set isDocsMenuOpen = activeSection in ['readme', 'readme-seed', 'readme-sqlite', 'guardiao', 'distintivo-om'] %}
      <section class="db-menu-group-block" data-menu-group>
        <button
          type="button"
          class="db-menu-group-toggle"
          data-menu-group-toggle
          data-group-key="docs-menu"
          aria-expanded="{{ isDocsMenuOpen ? 'true' : 'false' }}"
        >
          <span class="db-menu-group"><i class="bi bi-journal-text" aria-hidden="true"></i>Documentação</span>
          <i class="bi bi-chevron-down" aria-hidden="true"></i>
        </button>
        <div class="db-menu-group-items" data-menu-group-items {{ isDocsMenuOpen ? '' : 'hidden' }}>
          <a href="{{ app_base_path }}/readme" hx-boost="false" class="db-menu-item{{ activeSection == 'readme' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'readme' ? 'page' : 'false' }}">
            Guia do usuário
          </a>
          <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
          <a href="{{ app_base_path }}/readme-seed" hx-boost="false" class="db-menu-item{{ activeSection == 'readme-seed' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'readme-seed' ? 'page' : 'false' }}">
            Guia de Seed
          </a>
          <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
          <a href="{{ app_base_path }}/readme-sqlite" hx-boost="false" class="db-menu-item{{ activeSection == 'readme-sqlite' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'readme-sqlite' ? 'page' : 'false' }}">
            Guia do banco
          </a>
          <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
          <a href="{{ app_base_path }}/guardiao" hx-boost="false" class="db-menu-item{{ activeSection == 'guardiao' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'guardiao' ? 'page' : 'false' }}">
            Guardião
          </a>
          <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
          <a href="{{ app_base_path }}/distintivo-om" hx-boost="false" class="db-menu-item{{ activeSection == 'distintivo-om' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'distintivo-om' ? 'page' : 'false' }}">
            Distintivo da OM
          </a>
        </div>
      </section>
      <span class="db-menu-divider" aria-hidden="true"></span>
      <a href="{{ app_base_path }}/faq" hx-boost="false" class="db-menu-item{{ activeSection == 'faq' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'faq' ? 'page' : 'false' }}">
        <i class="bi bi-question-circle" aria-hidden="true"></i>
        <span>FAQ DO GUARDIÃO</span>
      </a>
      <span class="db-menu-divider" aria-hidden="true"></span>
      <a href="{{ app_base_path }}/solicitar-card" hx-boost="false" class="db-menu-item{{ activeSection == 'solicitar-card' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'solicitar-card' ? 'page' : 'false' }}">
        <i class="bi bi-person-vcard" aria-hidden="true"></i>
        <span>SOLICITAR CARD</span>
      </a>
      <span class="db-menu-divider" aria-hidden="true"></span>
      <a href="{{ app_base_path }}/contato" hx-boost="false" class="db-menu-item{{ activeSection == 'contato' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'contato' ? 'page' : 'false' }}">
        <i class="bi bi-envelope" aria-hidden="true"></i>
        <span>CONTATO</span>
      </a>
      {% if isAdminLogged|default(false) %}
        <span class="db-menu-divider" aria-hidden="true"></span>
        {% set isAdminMenuOpen = activeSection == 'admin' %}
        <section class="db-menu-group-block" data-menu-group>
          <button
            type="button"
            class="db-menu-group-toggle"
            data-menu-group-toggle
            data-group-key="admin-menu"
            aria-expanded="{{ isAdminMenuOpen ? 'true' : 'false' }}"
          >
            <span class="db-menu-group"><i class="bi bi-shield-lock" aria-hidden="true"></i>Admin</span>
            <i class="bi bi-chevron-down" aria-hidden="true"></i>
          </button>
          <div class="db-menu-group-items" data-menu-group-items {{ isAdminMenuOpen ? '' : 'hidden' }}>
            <a href="{{ app_base_path }}/admin?entity=groups" hx-boost="false" class="db-menu-item{{ activeSection == 'admin' and adminEntity|default('groups') == 'groups' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'admin' and adminEntity|default('groups') == 'groups' ? 'page' : 'false' }}">
              Grupos
            </a>
            <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
            <a href="{{ app_base_path }}/admin?entity=subgroups" hx-boost="false" class="db-menu-item{{ activeSection == 'admin' and adminEntity|default('') == 'subgroups' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'admin' and adminEntity|default('') == 'subgroups' ? 'page' : 'false' }}">
              Subgrupos
            </a>
            <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
            <a href="{{ app_base_path }}/admin?entity=cards" hx-boost="false" class="db-menu-item{{ activeSection == 'admin' and adminEntity|default('') == 'cards' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'admin' and adminEntity|default('') == 'cards' ? 'page' : 'false' }}">
              Cards
            </a>
            <span class="db-menu-divider db-menu-divider-sub" aria-hidden="true"></span>
            <a href="{{ app_base_path }}/admin?entity=requests" hx-boost="false" class="db-menu-item{{ activeSection == 'admin' and adminEntity|default('') == 'requests' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'admin' and adminEntity|default('') == 'requests' ? 'page' : 'false' }}">
              Solicitações
            </a>
          </div>
        </section>
        <form method="post" action="{{ app_base_path }}/logout" hx-boost="false" class="db-menu-form">
          <input type="hidden" name="csrf_token" value="{{ csrfToken|default('') }}">
          <button class="db-menu-item" type="submit"><i class="bi bi-box-arrow-right" aria-hidden="true"></i><span>SAIR</span></button>
        </form>
      {% else %}
        <span class="db-menu-divider" aria-hidden="true"></span>
        <a href="{{ app_base_path }}/login" hx-boost="false" class="db-menu-item{{ activeSection == 'login' ? ' is-active' : '' }}" aria-current="{{ activeSection == 'login' ? 'page' : 'false' }}">
          <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
          <span>LOGIN</span>
        </a>
      {% endif %}
    </nav>
  </aside>
  <div class="db-sidebar-backdrop" data-sidebar-backdrop aria-hidden="true"></div>

  <main class="db-main" aria-label="Área inicial do dashboard">
    {% include 'components/dashboard-topbar.twig' with {
      lastUpdated: lastUpdated,
      breadcrumbs: [
        { label: 'Dashboard', url: '{{ app_base_path }}' },
        { label: 'PAINEL DE CONTROLE' }
      ]
    } %}

    <div id="db-content" class="db-main-body">
      {% include 'components/dashboard-content-header.twig' with {
        breadcrumbs: [
          { label: 'Dashboard', url: '{{ app_base_path }}' },
          { label: 'PAINEL DE CONTROLE' }
        ],
        title: 'Visão geral do dashboard',
        subtitle: 'Selecione uma seção no menu lateral para visualizar os cards específicos'
      } %}

      <section class="db-summary" aria-label="Resumo geral do painel">
      <article class="db-card db-card--standard">
        <header class="db-card-head">
          <h3>Total de grupos</h3>
          <span class="db-badge is-ok">Resumo</span>
        </header>
        <p class="db-metric">{{ summary.groups }}</p>
      </article>

      <article class="db-card db-card--standard">
        <header class="db-card-head">
          <h3>Total de cards</h3>
          <span class="db-badge is-ok">Resumo</span>
        </header>
        <p class="db-metric">{{ summary.cards }}</p>
      </article>

      <article class="db-card db-card--standard">
        <header class="db-card-head">
          <h3>Última atualização</h3>
          <span class="db-badge is-ok">Resumo</span>
        </header>
        <p class="db-metric db-metric-small">{{ summary.lastUpdated }}</p>
      </article>
      </section>

      <section class="db-cards" aria-label="Acesso rápido às seções">
        {% for slug, section in sections %}
          <article class="db-card db-card--standard">
            <header class="db-card-head">
              <h3>{{ section.label|label_case }}</h3>
            </header>
            <p class="db-description">{{ section.description }}</p>
            <p class="db-card-link-wrap">
              <a class="db-card-link" href="{{ app_base_path }}/{{ slug }}">Abrir seção</a>
            </p>
          </article>
        {% endfor %}
      </section>

      {% include 'components/dashboard-footer.twig' with {
        lastUpdated: lastUpdated
      } %}
    </div>
  </main>
</div>
{% endblock %}

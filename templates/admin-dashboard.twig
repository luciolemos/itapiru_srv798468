<script>
  (function () {
    const syncNotificationBadge = (nextCount) => {
      const badge = document.querySelector('.db-notification-badge');
      if (!badge) {
        return;
      }

      const normalizedCount = Number.isFinite(nextCount) ? Math.max(0, Math.floor(nextCount)) : 0;
      badge.textContent = normalizedCount > 99 ? '99+' : String(normalizedCount);
      badge.setAttribute('aria-label', normalizedCount + ' solicitações pendentes');

      if (normalizedCount === 0) {
        badge.classList.add('is-zero');
      } else {
        badge.classList.remove('is-zero');
      }

      const panelCount = document.querySelector('.db-notification-header span');
      if (panelCount) {
        panelCount.textContent = String(normalizedCount);
      }
    };

    const decreaseNotificationBadge = () => {
      const badge = document.querySelector('.db-notification-badge');
      if (!badge) {
        return;
      }

      const currentRaw = String((badge.textContent || '').trim()).replace(/\+/g, '');
      const currentCount = parseInt(currentRaw, 10);
      if (Number.isNaN(currentCount)) {
        return;
      }

      syncNotificationBadge(Math.max(0, currentCount - 1));
    };

    const removeNotificationItem = (requestId) => {
      if (!Number.isFinite(requestId) || requestId <= 0) {
        return;
      }

      const panel = document.querySelector('.db-notification-panel');
      if (!panel) {
        return;
      }

      const item = panel.querySelector('.db-notification-item[data-request-id="' + requestId + '"]');
      if (!item) {
        return;
      }

      const list = item.closest('.db-notification-list');
      item.remove();

      if (!list) {
        return;
      }

      if (list.querySelector('.db-notification-item')) {
        return;
      }

      list.remove();

      if (!panel.querySelector('.db-notification-empty')) {
        const emptyState = document.createElement('p');
        emptyState.className = 'db-notification-empty';
        emptyState.textContent = 'Nenhuma solicitação pendente no momento.';
        const footer = panel.querySelector('.db-notification-footer');
        if (footer) {
          panel.insertBefore(emptyState, footer);
        } else {
          panel.appendChild(emptyState);
        }
      }
    };

    document.addEventListener('submit', (event) => {
      const form = event.target;
      if (!(form instanceof HTMLFormElement)) {
        return;
      }

      const action = String(form.getAttribute('action') || '');
      if (action !== '{{ app_base_path }}/admin/card-requests/approve' && action !== '{{ app_base_path }}/admin/card-requests/reject') {
        return;
      }

      if (form.dataset.badgeUpdated === '1') {
        return;
      }

      form.dataset.badgeUpdated = '1';

      const requestIdField = form.querySelector('input[name="id"]');
      const requestId = parseInt(String(requestIdField ? requestIdField.value : ''), 10);
      if (!Number.isNaN(requestId)) {
        removeNotificationItem(requestId);
      }

      decreaseNotificationBadge();
    }, true);

    const forms = document.querySelectorAll('form');
    forms.forEach((form) => {
      const groupSelect = form.querySelector('[data-subgroup-group-select]');
      const subgroupSelect = form.querySelector('[data-subgroup-select]');
      if (!groupSelect || !subgroupSelect) {
        return;
      }

      const allOptions = Array.from(subgroupSelect.options).map((option) => ({
        value: option.value,
        text: option.text,
        groupSlug: String(option.getAttribute('data-group-slug') || '').toLowerCase(),
        selected: option.selected,
      }));

      const updateSubgroups = () => {
        const selectedGroup = String(groupSelect.value || '').toLowerCase();
        const currentValue = String(subgroupSelect.value || '').toLowerCase();
        const filtered = allOptions.filter((item) => selectedGroup === '' || item.groupSlug === selectedGroup);

        subgroupSelect.innerHTML = '';

        filtered.forEach((item) => {
          const option = document.createElement('option');
          option.value = item.value;
          option.text = item.text;
          option.setAttribute('data-group-slug', item.groupSlug);
          subgroupSelect.appendChild(option);
        });

        if (filtered.length === 0) {
          const option = document.createElement('option');
          option.value = '';
          option.text = 'Nenhum subgrupo disponível para este grupo';
          subgroupSelect.appendChild(option);
          subgroupSelect.disabled = true;
          return;
        }

        subgroupSelect.disabled = false;

        const selectedStillExists = filtered.some((item) => item.value.toLowerCase() === currentValue);
        if (selectedStillExists) {
          subgroupSelect.value = currentValue;
          return;
        }

        const initiallySelected = filtered.find((item) => item.selected);
        subgroupSelect.value = initiallySelected ? initiallySelected.value : filtered[0].value;
      };

      groupSelect.addEventListener('change', updateSubgroups);
      updateSubgroups();
    });
  })();
</script>
{% endblock %}
